# 이 파일은 템플릿입니다. 복사해서 .env.local 을 만들고 실제 값을 채우세요.
#   cp .env.example .env.local
# .env.local 은 .gitignore 에 의해 커밋되지 않습니다.

# --- Supabase ---
# Project Settings > API 에서 확인.
# anon/publishable 키는 클라이언트에 노출되어도 안전하도록 설계돼 있으나,
# 데이터 보호는 키가 아니라 RLS(Row Level Security) 정책으로 합니다.
# → 모든 테이블에 RLS 를 활성화하고 사용자별 행 접근 정책을 반드시 설정하세요.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# --- 서버 전용 시크릿 (절대 커밋 금지, .env.local 에만) ---
# Supabase Project Settings > API > service_role (secret) — RLS 를 우회하므로 서버에서만 사용
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Vercel Cron 인증용 임의 문자열 (openssl rand -hex 32)
CRON_SECRET=
